{
  "name": "tradingtool-elec",
  "version": "1.0.0",
  "description": "Electron MT5 Trader Workbench",
  "main": "out/main/index.js",
  "author": "owen600",
  "developerContact": "Telegram: owen600",
  "scripts": {
    "dev:renderer": "vite",
    "dev:electron": "electron .",
    "dev": "electron-vite",
    "build:renderer": "vite build",
    "build:electron": "electron-vite build",
    "build": "electron-vite build",
    "build:python": "python -m PyInstaller --noconfirm \"python_service/mt5_service.spec\" --distpath \"python_service/dist\" --workpath \"python_service/build\"",
    "build:python:hardened": "python -m PyInstaller --noconfirm \"python_service/mt5_service_hardened.spec\" --distpath \"python_service/dist\" --workpath \"python_service/build\"",
    "build:python:debug": "pwsh -NoProfile -Command \"$env:MT5_SERVICE_CONSOLE='1'; python -m PyInstaller --noconfirm 'python_service/mt5_service.spec' --distpath 'python_service/dist' --workpath 'python_service/build'\"",
    "verify:packaging": "pwsh -File scripts/verify-packaging.ps1",
    "verify:packaging:hardened": "pwsh -File scripts/verify-packaging.ps1 -Hardened",
    "package:win": "npm run build && npm run build:python && npm run verify:packaging && node scripts/package-win.cjs",
    "package:win:hardened": "npm run build && npm run build:python:hardened && npm run verify:packaging:hardened && node scripts/package-win.cjs --hardened",
    "package:win:debug": "npm run build && npm run build:python:debug && npm run verify:packaging && node scripts/package-win.cjs --debug",
    "test:frontend": "vitest run",
    "test:electron": "playwright test tests/e2e/app-launch.spec.ts",
    "test": "npm run test:frontend && npm run test:electron"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lightweight-charts": "^5.2.0",
    "lucide-react": "^0.378.0",
    "next-themes": "^0.4.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.14.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.3.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.43.1",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^15.0.5",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.12.7",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "electron": "^30.0.0",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.1.0",
    "jimp": "^0.22.12",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.4.5",
    "vite": "^5.2.10",
    "vitest": "^1.5.0"
  },
  "build": {
    "appId": "com.tradingtool",
    "productName": "MT5 Trader Workbench",
    "copyright": "Author telegram owen600",
    "artifactName": "${productName} Setup ${buildVersion}.${ext}",
    "directories": {
      "output": "dist",
      "buildResources": "resources"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "python_service/dist/mt5_service",
        "to": "mt5_service",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/audio",
        "to": "audio",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/tray-icon.png",
        "to": "tray-icon.png"
      },
      {
        "from": "resources/help",
        "to": "help",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "storage/settings.default.json",
        "to": "storage/settings.json"
      }
    ]
  }
}
